---
import '@fontsource-variable/inter';
import '@fontsource/jetbrains-mono/400.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Rasha Hantash', description = 'Senior Software Engineer' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' fill='%23F5F3ED'/><text x='50%25' y='58%25' dominant-baseline='middle' text-anchor='middle' fill='%237A4B29' font-family='Georgia,serif' font-style='italic' font-weight='400' font-size='20'>r</text></svg>" />
  </head>
  <body class="min-h-screen flex flex-col bg-cream text-ink">
    <slot />
  </body>
</html>
