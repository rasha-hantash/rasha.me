---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, slug, tags = [] } = Astro.props;
const formattedDate = new Date(pubDate).toISOString().split('T')[0];
---
<a href={`/blog/${slug}`} class="grid-cell block group hover:bg-black hover:text-white transition-colors">
  <div class="crosshair top-[6px] right-[6px]"></div>
  <p class="text-[10px] uppercase tracking-widest opacity-50 mb-1">{formattedDate}</p>
  <h3 class="text-sm font-bold uppercase tracking-wide mb-2 group-hover:text-accent transition-colors">{title}</h3>
  <p class="text-sm opacity-70 mb-3">{description}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1">
      {tags.map((tag) => (
        <span class="tag group-hover:border-accent">{tag}</span>
      ))}
    </div>
  )}
  <div class="mt-3 text-[10px] uppercase tracking-widest opacity-50 group-hover:opacity-100 group-hover:text-accent transition-opacity">
    READ POST &rarr;
  </div>
</a>
