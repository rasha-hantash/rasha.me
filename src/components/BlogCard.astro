---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  index?: number;
}

const { title, description, pubDate, slug, tags = [], index } = Astro.props;
const formattedDate = new Date(pubDate).toISOString().split('T')[0];
const num = typeof index === 'number' ? String(index).padStart(2, '0') : null;
---
<li class="border-b border-ink/10 group">
  <a href={`/blog/${slug}`} class="block py-8 md:py-10">
    <div class="flex items-baseline gap-4 mb-3">
      {num && <span class="num-marker text-walnut/80">{num}</span>}
      <time class="num-marker text-ink/55" datetime={formattedDate}>{formattedDate}</time>
    </div>
    <h3 class="text-xl md:text-2xl font-light tracking-tight text-ink group-hover:text-walnut transition-colors">
      {title}
    </h3>
    <p class="mt-3 text-base font-light leading-relaxed text-ink/65 max-w-2xl">
      {description}
    </p>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-5">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </a>
</li>
