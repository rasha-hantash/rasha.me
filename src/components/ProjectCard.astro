---
interface Props {
  title: string;
  href: string;
  tags: string[];
}

const { title, href, tags } = Astro.props;
---
<a href={href} target="_blank" rel="noopener noreferrer" class="grid-cell block group hover:bg-black hover:text-white transition-colors">
  <div class="crosshair top-[6px] right-[6px]"></div>
  <h3 class="text-sm font-bold uppercase tracking-wide mb-3 group-hover:text-accent transition-colors">{title}</h3>
  <div class="flex flex-wrap gap-1">
    {tags.map((tag) => (
      <span class="tag group-hover:border-accent">{tag}</span>
    ))}
  </div>
  <div class="mt-3 text-[10px] uppercase tracking-widest opacity-50 group-hover:opacity-100 group-hover:text-accent transition-opacity">
    VIEW ON GITHUB &rarr;
  </div>
</a>
