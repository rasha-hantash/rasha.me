---
interface Props {
  title: string;
  href: string;
  description?: string;
  index?: number;
}

const { title, href, description, index } = Astro.props;
const num = typeof index === 'number' ? String(index).padStart(2, '0') : null;
---
<li class="border-b border-ink/10 group">
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="grid grid-cols-[auto,1fr,auto] items-baseline gap-x-5 md:gap-x-8 py-7 md:py-8 transition-colors"
  >
    {num && <span class="num-marker text-walnut/80 self-baseline">{num}</span>}
    <div class="flex flex-col md:flex-row md:items-baseline gap-1 md:gap-4 min-w-0">
      <h3 class="font-mono text-[15px] md:text-base text-ink group-hover:text-walnut transition-colors whitespace-nowrap">
        {title}
      </h3>
      {description && (
        <span class="hidden md:inline text-ink/30 select-none" aria-hidden="true">&mdash;</span>
      )}
      {description && (
        <p class="text-[15px] md:text-base font-light leading-snug text-ink/65 group-hover:text-ink/80 transition-colors">
          {description}
        </p>
      )}
    </div>
    <svg
      class="w-4 h-4 text-ink/30 group-hover:text-walnut group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all self-center"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      aria-hidden="true"
    >
      <path stroke-linecap="square" stroke-linejoin="miter" d="M7 17L17 7M9 7h8v8" />
    </svg>
  </a>
</li>
