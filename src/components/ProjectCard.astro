---
interface Props {
  title: string;
  href: string;
  tags: string[];
  description?: string;
  status?: string;
}

const { title, href, tags, description, status } = Astro.props;
---
<a href={href} target="_blank" rel="noopener noreferrer" class="grid-cell block group transition-colors">
  <div class="flex items-baseline justify-between gap-2 mb-3">
    <h3 class="text-sm font-bold uppercase tracking-wide">{title}</h3>
    {status && (
      <span class="text-[10px] font-bold uppercase tracking-wider text-accent whitespace-nowrap">{status}</span>
    )}
  </div>
  {description && (
    <p class="text-sm mb-4">{description}</p>
  )}
  <div class="flex flex-wrap gap-1">
    {tags.map((tag) => (
      <span class="tag">{tag}</span>
    ))}
  </div>
</a>
