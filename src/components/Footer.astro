---
const year = new Date().getFullYear();
---
<footer class="text-ink/55">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-8 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
    <span class="num-marker tracking-eyebrow !text-[12px] font-semibold">
      Made with <span aria-label="olive" role="img">🫒</span>
    </span>
    <span class="text-[11px] font-light">&copy; {year} Rasha Hantash</span>
  </div>
</footer>
