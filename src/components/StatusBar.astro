---
---
<div class="bg-black text-accent font-mono text-[10px] tracking-wider px-4 py-1.5 flex justify-between items-center overflow-x-auto whitespace-nowrap gap-4 border-b border-black" id="status-bar">
  <span>SYS:<span id="sb-os">---</span></span>
  <span>BROWSER:<span id="sb-browser">---</span></span>
  <span>RES:<span id="sb-res">---</span></span>
  <span>UTC:<span id="sb-utc">---</span></span>
  <span class="animate-pulse">STATUS:ONLINE</span>
</div>

<script>
  function getOS() {
    const ua = navigator.userAgent;
    if (ua.includes('Win')) return 'WINDOWS';
    if (ua.includes('Mac')) return 'MACOS';
    if (ua.includes('Linux')) return 'LINUX';
    if (ua.includes('Android')) return 'ANDROID';
    if (ua.includes('iPhone') || ua.includes('iPad')) return 'IOS';
    return 'UNKNOWN';
  }

  function getBrowser() {
    const ua = navigator.userAgent;
    if (ua.includes('Firefox')) return 'FIREFOX';
    if (ua.includes('Edg')) return 'EDGE';
    if (ua.includes('Chrome')) return 'CHROME';
    if (ua.includes('Safari')) return 'SAFARI';
    return 'OTHER';
  }

  document.getElementById('sb-os')!.textContent = getOS();
  document.getElementById('sb-browser')!.textContent = getBrowser();
  document.getElementById('sb-res')!.textContent = `${screen.width}x${screen.height}`;
  document.getElementById('sb-utc')!.textContent = new Date().toISOString().replace(/\.\d+Z$/, 'Z');
</script>
