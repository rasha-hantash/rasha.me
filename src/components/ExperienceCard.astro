---
interface Props {
  title: string;
  company: string;
  stack: string;
  duration: string;
  accomplishments: string[];
}

const { title, company, stack, duration, accomplishments } = Astro.props;
---
<details>
  <summary>
    <div class="flex-1 pr-4">
      <span class="font-bold">{title}</span>
      <span class="opacity-60 mx-1">|</span>
      <span>{company}</span>
      <span class="hidden sm:inline opacity-40 mx-1">[{stack}]</span>
    </div>
  </summary>
  <div class="details-content pl-0">
    <p class="text-[11px] uppercase tracking-wider opacity-50 mb-2">{duration}</p>
    <ul class="space-y-1">
      {accomplishments.map((a) => (
        <li class="text-sm pl-4 relative">
          <span class="absolute left-0 text-accent">&gt;</span>
          {a}
        </li>
      ))}
    </ul>
  </div>
</details>
