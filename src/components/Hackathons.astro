---
import HackathonCard from './HackathonCard.astro';
import { hackathons } from '../data/hackathons';
---
<div id="hackathons">
  <div class="border border-black p-4 mb-0">
    <p class="section-label">ARCHIVE // COMPETITIONS</p>
    <h2 class="section-title">Hackathons</h2>
  </div>
  <div class="border border-black p-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {hackathons.map((h) => (
        <HackathonCard title={h.title} status={h.status} description={h.description} tags={h.tags} />
      ))}
    </div>
  </div>
</div>
