---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) => new Date(d).toISOString().split('T')[0];
---
<section id="writing" class="relative overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.05] pointer-events-none"
    style="background-image: radial-gradient(circle at 1.5px 1.5px, #111 1px, transparent 0); background-size: 32px 32px;"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-7xl mx-auto px-6 md:px-10 py-24 md:py-32">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16">
      <header class="md:col-span-5">
        <span class="eyebrow">Field Notes</span>
        <h2 class="section-title mt-6">Writings</h2>
        <p class="mt-6 text-base md:text-lg font-light leading-[1.8] text-ink/70 max-w-md">
          Working notes on Go infrastructure, RAG pipelines, AI agents,
          and the systems thinking behind reliable software.
        </p>

        <a
          href="/blog"
          class="inline-flex items-center gap-3 mt-10 text-[12px] uppercase tracking-eyebrow link-underline"
        >
          All writing
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.25" d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      </header>

      <ol class="md:col-span-7 md:col-start-7 flex flex-col">
        {posts.length === 0 && (
          <li class="text-ink/50 text-sm">No posts yet.</li>
        )}
        {posts.map((post, i) => (
          <li class="border-t border-ink/10 first:border-t-0">
            <a
              href={`/blog/${post.id}`}
              class="block py-8 md:py-9 group"
            >
              <div class="flex items-baseline gap-4 mb-3">
                <span class="num-marker text-ink/50">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <time class="num-marker text-ink/50" datetime={fmt(post.data.pubDate)}>
                  {fmt(post.data.pubDate)}
                </time>
              </div>
              <h3 class="text-xl md:text-2xl font-light tracking-tight text-ink group-hover:text-walnut transition-colors">
                {post.data.title}
              </h3>
              <p class="mt-3 text-sm md:text-base font-light leading-relaxed text-ink/65 max-w-xl">
                {post.data.description}
              </p>
            </a>
          </li>
        ))}
        <li class="border-t border-ink/10"></li>
      </ol>
    </div>
  </div>
</section>
